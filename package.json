{
  "name": "@xhermes/cli",
  "version": "0.0.2",
  "description": "xHermes — talk to your Hermes agent from the terminal.",
  "type": "module",
  "bin": {
    "xhermes": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xHermescloud/cli.git"
  },
  "bugs": "https://github.com/xHermescloud/cli/issues",
  "homepage": "https://github.com/xHermescloud/cli#readme",
  "keywords": [
    "xhermes",
    "hermes-agent",
    "cli",
    "terminal",
    "nous-research"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "tsx src/index.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
